<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Horizons - Create New Listing</title>
</head>
<body>
    <form action="/listings" method="post">
        <input type="text" name="title" placeholder="Title" required>
        <input type="text" name="destination" placeholder="Destination" required>
        <br>
        <input type="text" name="type" placeholder="Type (e.g., Hotel, Expedition)" required>
        <textarea name="description" placeholder="Description"></textarea>
        <br>
        <br>
        <input type="number" name="price" placeholder="Price (INR)" required>
        <br>
        <br>
        <input type="number" name="durationInDays" placeholder="Duration in Days" required>
        <input type="number" name="capacity" placeholder="Capacity (passengers)" required>
        <br>
        <input type="text" name="amenities" placeholder="Amenities (comma-separated)">
        <input type="url" name="imageUrl" placeholder="Image URL">
        <br>   
        <label for="availableFrom">Time Period(from--to):</label>
        <input type="date" name="availableFrom" required>    
        <input type="date" name="availableTo" placeholder="Available To (YYYY-MM-DD)" required>
        <br><br>
        <button type="submit">Create Listing</button>
    </form>
</body>
</html>