!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nova Horizons - Create New Listing</title>
</head>
<body>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="post">
        <input type="text" name="title" value="<%= listing.title %>" required>
        <input type="text" name="destination" value="<%= listing.destination %>" required>
        <br>
        <input type="text" name="type" value="<%= listing.type %>" required>
        <textarea name="description" ><%= listing.description %></textarea>
        <br>
        <br>
        <input type="number" name="price" value="<%= listing.price %>" required>
        <br>
        <br>
        <input type="number" name="durationInDays" value="<%= listing.durationInDays %>" required>
        <input type="number" name="capacity" placeholder="Capacity (passengers)" value="<%= listing.capacity %>" required>
        <br>
        <input type="text" name="amenities" placeholder="Amenities (comma-separated)" value="<%= listing.amenities.join(', ') %>">
        <input type="url" name="imageUrl" placeholder="Image URL" value="<%= listing.imageUrl %>">
        <br>   
        <label for="availableFrom">Time Period(from--to):</label>
        <input type="date" name="availableFrom" value="<%= listing.availableFrom ? listing.availableFrom.toISOString().split('T')[0] : '' %>" required>    
        <input type="date" name="availableTo" placeholder="Available To (YYYY-MM-DD)" value="<%= listing.availableTo ? listing.availableTo.toISOString().split('T')[0] : '' %>" required>
        <br><br>
        <button type="submit">Update Listing</button>
    </form>
</body>
</html>