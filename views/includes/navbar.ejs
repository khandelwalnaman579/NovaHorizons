<style>
  .search-inp{
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }
    .search-btn{
      background-color: #fe434d;
      color: #fff;
      border-radius: 25px;
      padding: 0 1rem 0 1rem;
    }
    .search-btn:hover{
      background-color: #fe434d;
      color: #fff;
    }
    .search-btn i{
      display: inline;
      margin-right: 0.5rem;
    }
</style>
<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/"><i class="fa-brands fa-space-awesome"></i>Explore</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings/new">Add New Listing</a>
      </div>
      <div class="navbar-nav ms-auto">
        <form class="d-flex" role="search">
          <input class="form-control me-2 search-inp" type="search" placeholder="Search destination" aria-label="Search">
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>
      <div class="navbar-nav ms-auto">
        <% if(!currentUser) { %>
          <!-- currentUser is added to res.locals by our middleware, so it's available in all our views. It will be undefined if user is not authenticated, otherwise it will contain the authenticated user's info. -->
          <a class="nav-link" href="/login">Log In</a>
          <a class="nav-link" href="/signup">Sign Up</a>
        <% } else { %>
          <span class="navbar-text me-3">Welcome, <%= currentUser.username %>!</span>
          <a class="nav-link" href="/logout">Log Out</a>

        <% } %>
    </div>
  </div>
</nav> 
<script src="/js/search.js"></script>