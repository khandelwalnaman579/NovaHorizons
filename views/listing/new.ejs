<% layout('/layouts/boilerplate') %>
    <h1 class="new-title">Create New Listing</h1>
    <form action="/listings" method="post" class="needs-validation" novalidate  enctype="multipart/form-data">
      <div class="row"> 
       <div class="col-8 offset-2"> 
        <div class="row">
            <div class="col-md-8">
               <label for="listing[title]" class="form-label">Title</label>
               <input type="text" name="listing[title]" placeholder="Orbital Resort" class="form-control" required>
            </div>
            <div class="col-md-4">
              <label for="listing[destination]" class="form-label">Destination</label>
              <input type="text" name="listing[destination]" placeholder="Moon" class="form-control" required>
            </div>
        </div>
        <br>
        <div>
            <label for="listing[description]" class="form-label">Description</label>
            <textarea name="listing[description]" placeholder="Description" class="form-control"></textarea>
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
                <label for="listing[price]" class="form-label">Price (INR)</label>
                <input type="number" name="listing[price]" placeholder="Price (INR)" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label for="listing[durationInDays]" class="form-label">Duration in Days</label>
                <input type="number" name="listing[durationInDays]" placeholder="Duration in Days" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label for="listing[capacity]" class="form-label">Capacity</label>
                <input type="number" name="listing[capacity]" placeholder="Capacity (passengers)" class="form-control" required>
            </div>
        </div>
        <br>
        <div class="mt-3">
              <label for="listing[image]" class="form-label">Upload Listing Image:</label>
              <input type="file" name="listing[image]" class="form-control" required> 
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
              <label for="listing[type]" class="form-label">Type</label>
              <input type="text" name="listing[type]" placeholder="Type (e.g., Hotel, Expedition)" class="form-control" required>
            </div>
            <div class="col-md-8">
              <label for="listing[amenities]" class="form-label">Amenities</label>
              <input type="text" name="listing[amenities]" placeholder="Amenities (comma-separated)" class="form-control">
            </div>
        </div>
        <br>
        <div>
            <label for="listing[availableFrom]" class="form-label">Time Period(from--to):</label>
            <div class="row">
                <div class="col-md-4">
                    <input type="date" id="availableFrom" name="listing[availableFrom]" class="form-control" required>
                </div>
                <div class="col-md-4">
                    <input type="date" id="availableTo" name="listing[availableTo]" class="form-control" required>
                </div>
            </div>
        </div>
        <br>
        <button type="submit" class="btn btn-dark add-btn">Add</button>
        </div>
      </div>
    </form>
</body>
</html>