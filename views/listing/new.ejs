<% layout('/layouts/boilerplate') %>
    <h1 class="new-title">Create New Listing</h1>
    <form action="/listings" method="post" class="needs-validation" novalidate>
      <div class="row"> 
       <div class="col-8 offset-2"> 
        <div class="row">
            <div class="col-md-8">
               <label for="title"class="form-label">Title</label>
               <input type="text" name="title" placeholder="Orbital Resort" class="form-control" required>
            </div>
            <div class="col-md-4">
              <label for="destination" class="form-label">Destination</label>
              <input type="text" name="destination" placeholder="Moon" class="form-control" required>
            </div>
        </div>
        <br>
        <div>
            <label for="description" class="form-label">Description</label>
            <textarea name="description" placeholder="Description" class="form-control"></textarea>
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
                <label for="price" class="form-label">Price (INR)</label>
                <input type="number" name="price" placeholder="Price (INR)" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label for="durationInDays" class="form-label">Duration in Days</label>
                <input type="number" name="durationInDays" placeholder="Duration in Days" class="form-control" required>
            </div>
            <div class="col-md-4">
                <label for="capacity" class="form-label">Capacity</label>
                <input type="number" name="capacity" placeholder="Capacity (passengers)" class="form-control" required>
            </div>
        </div>
        <br>
        <div>
            <label for="imageUrl" class="form-label">Image URL</label>
            <input type="url" name="imageUrl" placeholder="Image URL" class="form-control">
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
              <label for="type" class="form-label">Type</label>
              <input type="text" name="type" placeholder="Type (e.g., Hotel, Expedition)" class="form-control" required>
            </div>
            <div class="col-md-8">
              <label for="amenities" class="form-label">Amenities</label>
              <input type="text" name="amenities" placeholder="Amenities (comma-separated)" class="form-control">
            </div>
        </div>
        <br>
        <div>
            <label for="availableFrom" class="form-label">Time Period(from--to):</label>
            <div class="row">
                <div class="col-md-4">
                    <input type="date" id="availableFrom" name="availableFrom" class="form-control">
                </div>
                <div class="col-md-4">
                    <input type="date" id="availableTo" name="availableTo" class="form-control">
                </div>
            </div>
        </div>
        <br>
        <button type="submit" class="btn btn-dark add-btn">Add</button>
        </div>
      </div>
    </form>
</body>
</html>