
<% layout('/layouts/boilerplate') %>
    <h1 class="edit-title">Edit Listing</h1>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="post" class="needs-validation" novalidate>
        <div class="row">
            <div class="col-md-8">
               <label for="title"class="form-label">Title</label>
               <input type="text" name="title" value="<%= listing.title %>" class="form-control" required>
            </div>
            <div class="col-md-4">
               <label for="destination" class="form-label">Destination</label>
               <input type="text" name="destination" value="<%= listing.destination %>" class="form-control" required>
            </div>
        </div>
        <br>
        <div class="row">
            <div class="col">
                <label for="description" class="form-label">Description</label>
                <textarea name="description" class="form-control" required><%= listing.description %></textarea>
            </div>
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
                 <label for="price" class="form-label">Price</label>
                 <input type="number" name="price" value="<%= listing.price %>" class="form-control" required>
            </div>
            <div class="col-md-4">
                 <label for="durationInDays" class="form-label">Duration in Days</label>
                 <input type="number" name="durationInDays" value="<%= listing.durationInDays %>" class="form-control" required>
            </div>
            <div class="col-md-4">
                   <label for="capacity" class="form-label">Capacity</label>
                   <input type="number" name="capacity" placeholder="Capacity (passengers)" value="<%= listing.capacity %>" class="form-control" required>
            </div>
        </div>
        <br>
        <div class="row">
            <div class="col-md-4">
                <label for="type" class="form-label">Type</label>
                <input type="text" name="type" placeholder="Type (e.g., Hotel, Expedition)" value="<%= listing.type %>" class="form-control" required>
            </div>
            <div class="col-md-8">
                <label for="amenities" class="form-label">Amenities</label>
                <input type="text" name="amenities" placeholder="Amenities (comma-separated)" value="<%= listing.amenities.join(', ') %>" class="form-control">
            </div>
        </div>
        <br>
        <label for="imageUrl" class="form-label">Image Url</label>
        <input type="url" name="imageUrl" placeholder="Image URL" value="<%= listing.imageUrl %>" class="form-control" required>
        <br>
        <div class="row">
            <label for="availableFrom" class="form-label">Time Period(from--to):</label>
            <div class="col-4">
                <input type="date" name="availableFrom" value="<%= listing.availableFrom ? listing.availableFrom.toISOString().split('T')[0] : '' %>" class="form-control">    
            </div>
            <div class="col-4">
                <input type="date" name="availableTo" placeholder="Available To (YYYY-MM-DD)" value="<%= listing.availableTo ? listing.availableTo.toISOString().split('T')[0] : '' %>" class="form-control">
            </div> 
        </div>
        <br>
        <button type="submit" class="btn update-btn">Update Listing</button>
    </form>